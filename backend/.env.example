# Server
NODE_ENV=development
PORT=4000

# Postgres
DATABASE_URL=postgres://funfriday:funfriday_dev@localhost:5432/funfriday

# Auth — generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
# Set true only when the app is served over HTTPS
COOKIE_SECURE=false

# Frontend origin(s), comma separated
CORS_ORIGIN=http://localhost:3000

# Fun Friday window is Friday 17:00-17:30 in this timezone
FUN_FRIDAY_TZ=Asia/Kolkata
# Dev/testing only: set true to keep the arena open all week
FUN_FRIDAY_ALWAYS_OPEN=false
